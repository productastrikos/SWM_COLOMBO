Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^(client|server|netlify|node_modules|scripts)(/|$) - [F,L]
  RewriteRule ^(package(-lock)?\.json|app\.js|HOSTINGER_DEPLOY\.md|README\.md|WALKTHROUGH\.md|netlify\.toml|\.gitignore)$ - [F,L]
  RewriteRule (^|/)\. - [F,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>
